<aside class="adversary-sidebar-sheet compact-footer-card compact-footer-card-v2">
  <div class="compact-footer-inner">
    <div class="compact-divider-title compact-divider-title-v2">
      <span>{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}} &amp; {{localize 'DAGGERHEART.GENERAL.stress'}}</span>
    </div>

    <div class="compact-threshold-row compact-threshold-row-v2">
      <div class="compact-threshold-chip compact-threshold-chip-v2">
        <span class="compact-threshold-name">{{localize 'DAGGERHEART.GENERAL.DamageThresholds.minor'}}</span>
      </div>

      <span class="compact-threshold-value compact-threshold-value-v2">{{compact.thresholdMajor}}</span>

      <div class="compact-threshold-chip compact-threshold-chip-v2">
        <span class="compact-threshold-name">{{localize 'DAGGERHEART.GENERAL.DamageThresholds.major'}}</span>
      </div>

      <span class="compact-threshold-value compact-threshold-value-v2">{{compact.thresholdSevere}}</span>

      <div class="compact-threshold-chip compact-threshold-chip-v2">
        <span class="compact-threshold-name">{{localize 'DAGGERHEART.GENERAL.DamageThresholds.severe'}}</span>
      </div>
    </div>

    {{#if useResourcePips}}
      <div class="compact-resource-pips compact-resource-pips-v2">
        <div class="compact-pip-row compact-pip-row--hp">
          <span class="compact-resource-label">{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}} ({{compact.hitPoints.max}})</span>
          <button type="button" class="compact-pip-step" data-compact-resource-step="hitPoints" data-direction="-1" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}}">-</button>
          <div class="compact-pip-track">
            {{#each compact.hitPointSlotGroups as |group|}}
              <div class="compact-pip-group">
                {{#each group as |slot|}}
                  <button
                    type="button"
                    class="compact-pip {{#if slot.filled}}filled{{/if}}"
                    data-action="toggleHitPoints"
                    data-value="{{slot.value}}"
                    data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}} {{slot.value}}"
                  ></button>
                {{/each}}
              </div>
            {{/each}}
          </div>
          <button type="button" class="compact-pip-step" data-compact-resource-step="hitPoints" data-direction="1" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}}">+</button>
        </div>

        <div class="compact-pip-row compact-pip-row--stress">
          <span class="compact-resource-label">{{localize 'DAGGERHEART.GENERAL.stress'}} ({{compact.stress.max}})</span>
          <button type="button" class="compact-pip-step" data-compact-resource-step="stress" data-direction="-1" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.stress'}}">-</button>
          <div class="compact-pip-track">
            {{#each compact.stressSlotGroups as |group|}}
              <div class="compact-pip-group">
                {{#each group as |slot|}}
                  <button
                    type="button"
                    class="compact-pip {{#if slot.filled}}filled{{/if}}"
                    data-action="toggleStress"
                    data-value="{{slot.value}}"
                    data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.stress'}} {{slot.value}}"
                  ></button>
                {{/each}}
              </div>
            {{/each}}
          </div>
          <button type="button" class="compact-pip-step" data-compact-resource-step="stress" data-direction="1" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.stress'}}">+</button>
        </div>
      </div>
    {{else}}
      <div class="compact-resource-row compact-resource-row-v2">
        <label class="compact-resource-field compact-resource-field-v2">
          <span class="compact-resource-label">{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}}:</span>
          <input
            type="number"
            name="system.resources.hitPoints.value"
            value="{{compact.hitPoints.value}}"
            min="0"
            max="{{compact.hitPoints.max}}"
            data-allow-delta="true"
          />
          <span class="compact-resource-max">{{compact.hitPoints.max}}</span>
        </label>

        <label class="compact-resource-field compact-resource-field-v2">
          <span class="compact-resource-label">{{localize 'DAGGERHEART.GENERAL.stress'}}:</span>
          <input
            type="number"
            name="system.resources.stress.value"
            value="{{compact.stress.value}}"
            min="0"
            max="{{compact.stress.max}}"
            data-allow-delta="true"
          />
          <span class="compact-resource-max">{{compact.stress.max}}</span>
        </label>
      </div>
    {{/if}}

    {{#if (lt source.system.criticalThreshold 20)}}
      <div class="compact-footer-meta compact-footer-meta-v2">
        <span>
          {{localize 'DAGGERHEART.GENERAL.criticalShort'}}: {{source.system.criticalThreshold}}+
        </span>
      </div>
    {{/if}}

    {{#if (and showAttribution document.system.attribution.artist)}}
      <label class="artist-attribution compact-artist-attribution">{{localize 'DAGGERHEART.GENERAL.artistAttribution' artist=document.system.attribution.artist}}</label>
    {{/if}}
  </div>
</aside>
