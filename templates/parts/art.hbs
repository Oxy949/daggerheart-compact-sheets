<div class="dhca-header__art-layer">
  {{#if document.img}}
    <div
      class="dhca-header__art"
      data-dhca-art-menu
      data-dhca-edit="img"
      aria-label="{{localize 'DHCS.ContextMenu.ArtMenuLabel'}}"
    >
      <img class="dhca-header__art-image" src="{{document.img}}" alt="" aria-hidden="true" />
    </div>
  {{/if}}
</div>
