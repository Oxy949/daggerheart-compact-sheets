<header class="adversary-header-sheet dhca-section dhca-section--header dhca-header">
  <div class="dhca-header__adornment" aria-hidden="true">
    <div class="dhca-header__ribbon">{{adversaryType}}</div>
    <div class="dhca-header__tier">{{source.system.tier}}</div>
  </div>

  <div class="dhca-header__identity">
    <h1
      class="input actor-name dhca-header__name"
      contenteditable="plaintext-only"
      data-property="name"
      placeholder="{{localize 'DAGGERHEART.GENERAL.actorName'}}"
    >{{source.name}}</h1>
  </div>

  {{#if description}}
    <div class="dhca-header__description">{{{description}}}</div>
  {{/if}}

  {{#unless compact.showResourceBlock}}
    <div class="dhca-header__compact-summary" aria-label="{{localize 'DAGGERHEART.GENERAL.details'}}">
      <div class="dhca-header__compact-summary-row">
        <span>
          <strong>{{localize 'DAGGERHEART.GENERAL.difficulty'}}:</strong>
          {{#if source.system.difficulty includeZero=true}}{{source.system.difficulty}}{{else}}-{{/if}}
        </span>
        <span class="dhca-summary__separator">|</span>
        <span>
          <strong>{{localize 'DHCS.Labels.Thresholds'}}:</strong>
          {{compact.thresholds.major}}/{{compact.thresholds.severe}}
        </span>
      </div>
      <div class="dhca-header__compact-summary-row">
        <span>
          <strong>{{localize 'DAGGERHEART.GENERAL.HitPoints.short'}}:</strong>
          {{#if compact.showInteractionButtons}}
            <span
              class="input dhca-header__resource-current"
              contenteditable="plaintext-only"
              data-property="system.resources.hitPoints.value"
              data-dhca-resource-path="system.resources.hitPoints.value"
              data-dhca-resource-max="{{compact.resources.hitPoints.max}}"
            >{{compact.resources.hitPoints.value}}</span>/<span
              class="dhca-header__resource-max"
              data-dhca-resource-path="system.resources.hitPoints.value"
              data-dhca-resource-max="{{compact.resources.hitPoints.max}}"
            >{{compact.resources.hitPoints.max}}</span>
          {{else}}
            {{compact.resources.hitPoints.max}}
          {{/if}}
        </span>
        <span class="dhca-summary__separator">|</span>
        <span>
          <strong>{{localize 'DAGGERHEART.GENERAL.stress'}}:</strong>
          {{#if compact.showInteractionButtons}}
            <span
              class="input dhca-header__resource-current"
              contenteditable="plaintext-only"
              data-property="system.resources.stress.value"
              data-dhca-resource-path="system.resources.stress.value"
              data-dhca-resource-max="{{compact.resources.stress.max}}"
            >{{compact.resources.stress.value}}</span>/<span
              class="dhca-header__resource-max"
              data-dhca-resource-path="system.resources.stress.value"
              data-dhca-resource-max="{{compact.resources.stress.max}}"
            >{{compact.resources.stress.max}}</span>
          {{else}}
            {{compact.resources.stress.max}}
          {{/if}}
        </span>
      </div>
    </div>
  {{/unless}}

  <div class="dhca-header__stats">
    {{#if compact.showResourceBlock}}
      <div class="dhca-summary__line">
        <span class="dhca-summary__label">{{localize 'DAGGERHEART.GENERAL.difficulty'}}:</span>
        <span class="dhca-summary__value">{{ifThen source.system.difficulty source.system.difficulty '-'}}</span>
      </div>
    {{/if}}
    <div class="dhca-summary__line">
      <span class="dhca-summary__label">{{localize 'DAGGERHEART.GENERAL.attack'}}:</span>
      <span class="dhca-summary__value">
        {{#if compact.attackBonus includeZero=true}}
          {{numberFormat compact.attackBonus sign=true}}
        {{else}}
          -
        {{/if}}
      </span>
    </div>
  </div>

  <div class="dhca-header__attack">
    <ul class="dhca-header__attack-list">
      {{> 'daggerheart.inventory-item-compact'
        item=document.system.attack
        type='attack'
        noCompendiumEdit=true
        hideContextMenu=true
        hideControls=(not compact.showInteractionButtons)
        hideTooltip=false
      }}
    </ul>
  </div>

  <div class="dhca-header__details{{#unless compact.hasExperiences}} dhca-header__details--single{{/unless}}">
    {{#if compact.hasExperiences}}
      <section class="dhca-detail-panel dhca-detail-panel--experience">
        <h3 class="dhca-detail-panel__title">{{localize 'DAGGERHEART.GENERAL.experience.plural'}}:</h3>
        <div class="dhca-experience-list">
          {{#each source.system.experiences as |experience id|}}
            <div
              class="dhca-experience-row"
              {{#unless @root.compact.showInteractionButtons}}data-tooltip-text="{{experience.description}}"{{/unless}}
            >
              {{#if @root.compact.showInteractionButtons}}
                <button
                  type="button"
                  class="dhca-experience-action"
                  data-action="sendExpToChat"
                  data-id="{{id}}"
                  data-tooltip-text="{{localize 'DAGGERHEART.UI.Tooltip.sendToChat'}}"
                >
                  <span class="dhca-experience-name">{{experience.name}}</span>
                  <span class="dhca-experience-value">+{{experience.value}}</span>
                </button>
              {{else}}
                <span class="dhca-experience-action dhca-experience-action--static">
                  <span class="dhca-experience-name">{{experience.name}}</span>
                  <span class="dhca-experience-value">+{{experience.value}}</span>
                </span>
              {{/if}}
            </div>
          {{/each}}
        </div>
      </section>
    {{/if}}

    <section class="dhca-detail-panel dhca-detail-panel--motives">
      <h3 class="dhca-detail-panel__title">{{localize 'DAGGERHEART.ACTORS.Adversary.FIELDS.motivesAndTactics.label'}}:</h3>
      <div class="dhca-rich-text dhca-rich-text--motives">{{{source.system.motivesAndTactics}}}</div>
    </section>
  </div>

  <div class="dhca-header__toolbar">
    {{> 'modules/daggerheart-compact-sheets/templates/parts/tab-nav.hbs'}}
    <div class="dhca-header-actions">
      {{#if compact.showInteractionButtons}}
        <button type="button" data-action="reactionRoll" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.Roll.reaction'}}">
          <i class="fa-solid fa-dice-d20"></i>
        </button>
      {{/if}}
      <button type="button" data-action="openSettings" data-tooltip-text="{{localize 'DAGGERHEART.UI.Tooltip.openSheetSettings'}}">
        <i class="fa-solid fa-wrench"></i>
      </button>
    </div>
  </div>
</header>
