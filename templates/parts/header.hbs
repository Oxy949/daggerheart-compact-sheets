<header class="adversary-header-sheet compact-card compact-card-v2 compact-header-simple">
  <div class="compact-identity-line">
    <h1
      class="input actor-name compact-actor-name compact-actor-name-v2 compact-identity-name"
      contenteditable="plaintext-only"
      data-property="name"
      placeholder="{{localize 'DAGGERHEART.GENERAL.actorName'}}"
    >{{source.name}}<span class="compact-identity-comma">,</span></h1>
    <span class="compact-identity-meta">
      <span>Тир {{source.system.tier}}</span>
      <span>{{adversaryType}}</span>
    </span>
  </div>

  {{#if description}}
    <div class="compact-adversary-description">{{{description}}}</div>
  {{/if}}

  <div class="compact-summary-lines compact-summary-lines-v2">
    <div class="compact-summary-line">
      <span class="compact-summary-label">{{localize 'DAGGERHEART.GENERAL.difficulty'}}:</span>
      <span class="compact-summary-value">{{ifThen source.system.difficulty source.system.difficulty '-'}}</span>
    </div>
    <div class="compact-summary-line">
      <span class="compact-summary-label">{{localize 'DAGGERHEART.GENERAL.attack'}}:</span>
      <span class="compact-summary-value">
        {{#if compact.attackBonus includeZero=true}}
          {{numberFormat compact.attackBonus sign=true}}
        {{else}}
          -
        {{/if}}
      </span>
    </div>
  </div>

  <div class="compact-attack-row compact-attack-row-v2">
    <ul class="compact-attack-list">
      {{> 'daggerheart.inventory-item-compact'
        item=document.system.attack
        type='attack'
        noCompendiumEdit=true
        hideTooltip=false
      }}
    </ul>
  </div>

  <div class="compact-detail-grid compact-detail-grid-v2">
    <section class="compact-detail-panel compact-experience-panel compact-detail-panel-v2">
      <h3 class="compact-column-heading">{{localize 'DAGGERHEART.GENERAL.experience.plural'}}</h3>
      {{#if compact.hasExperiences}}
        <div class="compact-experience-list compact-experience-list-v2">
          {{#each source.system.experiences as |experience id|}}
            <div class="compact-experience-row compact-experience-row-v2" data-tooltip-text="{{experience.description}}">
              <span class="compact-experience-name">{{experience.name}}</span>
              <span class="compact-experience-value">+{{experience.value}}</span>
              <a class="compact-inline-action" data-action="sendExpToChat" data-id="{{id}}" data-tooltip-text="{{localize 'DAGGERHEART.UI.Tooltip.sendToChat'}}">
                <i class="fa-regular fa-message"></i>
              </a>
            </div>
          {{/each}}
        </div>
      {{else}}
        <div class="compact-empty">-</div>
      {{/if}}
    </section>

    <section class="compact-detail-panel compact-motives-panel compact-detail-panel-v2">
      <h3 class="compact-column-heading">{{localize 'DAGGERHEART.ACTORS.Adversary.FIELDS.motivesAndTactics.label'}}</h3>
      <div class="compact-rich-text compact-rich-text-v2">{{{source.system.motivesAndTactics}}}</div>
    </section>
  </div>

  <div class="compact-navigation-row compact-navigation-row-v2">
    <div class="compact-tab-nav compact-tab-nav-v2">
      {{> 'systems/daggerheart/templates/sheets/global/tabs/tab-navigation.hbs'}}
    </div>
    <div class="compact-header-buttons compact-header-buttons-v2">
      <button type="button" data-action="reactionRoll" data-tooltip-text="{{localize 'DAGGERHEART.GENERAL.Roll.reaction'}}">
        <i class="fa-solid fa-dice-d20"></i>
      </button>
      <button type="button" data-action="openSettings" data-tooltip-text="{{localize 'DAGGERHEART.UI.Tooltip.openSheetSettings'}}">
        <i class="fa-solid fa-wrench"></i>
      </button>
    </div>
  </div>
</header>
